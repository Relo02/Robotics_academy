<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="diff_drive_robot">

  <!-- ======================================================== -->
  <!--  Parameters                                               -->
  <!-- ======================================================== -->
  <xacro:property name="base_length"  value="0.40"/>
  <xacro:property name="base_width"   value="0.30"/>
  <xacro:property name="base_height"  value="0.15"/>
  <xacro:property name="wheel_radius" value="0.075"/>
  <xacro:property name="wheel_width"  value="0.05"/>
  <xacro:property name="wheel_sep"    value="0.30"/>   <!-- half-track -->
  <xacro:property name="caster_r"     value="0.025"/>

  <!-- ======================================================== -->
  <!--  Materials                                                -->
  <!-- ======================================================== -->
  <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
  <material name="light_grey"><color rgba="0.7 0.7 0.7 1"/></material>
  <material name="blue"><color rgba="0.0 0.4 0.8 1"/></material>
  <material name="black"><color rgba="0.0 0.0 0.0 1"/></material>

  <!-- ======================================================== -->
  <!--  Macros                                                   -->
  <!-- ======================================================== -->
  <xacro:macro name="wheel" params="name side reflect">
    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="0 ${reflect * wheel_sep} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1"/>
    </joint>
  </xacro:macro>

  <!-- ======================================================== -->
  <!--  Base footprint                                           -->
  <!-- ======================================================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================== -->
  <!--  Base link                                                -->
  <!-- ======================================================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 ${base_height/2}"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <!-- ======================================================== -->
  <!--  Wheels                                                   -->
  <!-- ======================================================== -->
  <xacro:wheel name="left"  side="left"  reflect=" 1"/>
  <xacro:wheel name="right" side="right" reflect="-1"/>

  <!-- Front caster -->
  <link name="caster_link">
    <visual>
      <geometry><sphere radius="${caster_r}"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_r}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="${base_length/2 - caster_r} 0 ${-wheel_radius + caster_r}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================== -->
  <!--  IMU                                                      -->
  <!-- ======================================================== -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.01"/></geometry>
      <material name="blue"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================== -->
  <!--  2D LiDAR                                                 -->
  <!-- ======================================================== -->
  <link name="lidar_link">
    <visual>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="${base_length/2 - 0.05} 0 ${base_height + 0.05}" rpy="0 0 0"/>
  </joint>

  <!-- ======================================================== -->
  <!--  Stereo Camera                                            -->
  <!-- ======================================================== -->
  <xacro:property name="stereo_baseline" value="0.12"/>   <!-- 12 cm baseline -->

  <!-- Stereo camera housing -->
  <link name="stereo_camera_link">
    <visual>
      <geometry><box size="0.03 ${stereo_baseline + 0.04} 0.03"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="stereo_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="stereo_camera_link"/>
    <origin xyz="${base_length/2} 0 ${base_height + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- Left lens -->
  <link name="camera_left_link"/>
  <joint name="camera_left_joint" type="fixed">
    <parent link="stereo_camera_link"/>
    <child  link="camera_left_link"/>
    <origin xyz="0 ${stereo_baseline/2} 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_left_optical_link"/>
  <joint name="camera_left_optical_joint" type="fixed">
    <parent link="camera_left_link"/>
    <child  link="camera_left_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- Right lens -->
  <link name="camera_right_link"/>
  <joint name="camera_right_joint" type="fixed">
    <parent link="stereo_camera_link"/>
    <child  link="camera_right_link"/>
    <origin xyz="0 ${-stereo_baseline/2} 0" rpy="0 0 0"/>
  </joint>

  <link name="camera_right_optical_link"/>
  <joint name="camera_right_optical_joint" type="fixed">
    <parent link="camera_right_link"/>
    <child  link="camera_right_optical_link"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ======================================================== -->
  <!--  Gazebo plugins                                           -->
  <!-- ======================================================== -->
  <!-- ros2_control interface -->
  <ros2_control name="diff_drive_system" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find diff_drive_description)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- IMU plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros><topic>imu/data</topic></ros>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- LiDAR plugin -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>${-pi}</min_angle>
            <max_angle>${pi}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
        </range>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros><topic>scan</topic></ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Stereo camera plugin (left) -->
  <gazebo reference="camera_left_link">
    <sensor name="stereo_camera" type="multicamera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <camera name="left">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>30</far></clip>
      </camera>
      <camera name="right">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.05</near><far>30</far></clip>
        <pose>0 ${-stereo_baseline} 0 0 0 0</pose>
      </camera>
      <plugin name="stereo_camera_plugin" filename="libgazebo_ros_multicamera.so">
        <ros>
          <remapping>~/left/image_raw:=stereo/left/image_raw</remapping>
          <remapping>~/right/image_raw:=stereo/right/image_raw</remapping>
          <remapping>~/left/camera_info:=stereo/left/camera_info</remapping>
          <remapping>~/right/camera_info:=stereo/right/camera_info</remapping>
        </ros>
        <left_frame_name>camera_left_optical_link</left_frame_name>
        <right_frame_name>camera_right_optical_link</right_frame_name>
        <hack_baseline>${stereo_baseline}</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>

</robot>
