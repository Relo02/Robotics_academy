# Environment variables for Docker Compose
# Copy this file to .env and modify as needed

# Display configuration
# Linux: Usually :0 or :1
# Windows with VcXsrv: host.docker.internal:0
# macOS with XQuartz: host.docker.internal:0
DISPLAY=:0

# ROS2 Domain ID (change if multiple students on same network)
ROS_DOMAIN_ID=0
